---
const birthDate = new Date(2003, 11, 14); // Nov 14, 2003
const totalYears = 90;
const weeksPerYear = 52;
const totalWeeks = totalYears * weeksPerYear;
const now = new Date();
const msPerWeek = 1000 * 60 * 60 * 24 * 7;
const weeksLived = Math.floor((now.getTime() - birthDate.getTime()) / msPerWeek);
---
<section id="weeks-grid">
  <h2 class="section-header">My Life in Weeks</h2>
  <p class="weeks-subtitle">
    {weeksLived.toLocaleString()} weeks lived out of {totalWeeks.toLocaleString()} ({totalYears} years)
  </p>
  <div class="grid-container">
    {Array.from({ length: totalWeeks }).map((_, i) => (
      <div class={`week-square ${i < weeksLived ? "lived" : "future"}`}></div>
    ))}
  </div>
</section>
<style>
  #weeks-grid {
    padding: 3rem 1rem;
    text-align: center;
  }
  .section-header {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }
  .weeks-subtitle {
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }
  .grid-container {
    display: grid;
    grid-template-columns: repeat(120, minmax(1px, 1fr));
    gap: 1px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .week-square {
    width: 100%;
    aspect-ratio: 1 / 1;
  }
  .week-square.future {
    background-color: var(--glass-bg);
    border: 1px solid var(--glass-border);
  }
  .week-square.lived {
    background-color: rgba(100, 160, 220, 0.9);
    box-shadow:
      0 0 4px rgba(100, 160, 220, 0.8),
      0 0 8px rgba(100, 160, 220, 0.4);
  }
  @media (max-width: 600px) {
    .grid-container {
      grid-template-columns: repeat(60, minmax(1px, 1fr));
    }
  }
</style>