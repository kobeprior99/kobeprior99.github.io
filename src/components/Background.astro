---
// Background.astro
---
<canvas id="sine-bg"></canvas>

<style>
  #sine-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 1;
    pointer-events: none;
    z-index: 0;
  }
  html:not(.dark) #sine-bg {
    opacity: 1;
  }
</style>

<script>
  const canvas = document.getElementById('sine-bg') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  let W = 0, H = 0;

  function resize() {
    W = window.innerWidth;
    H = window.innerHeight;
    canvas.width = W * devicePixelRatio;
    canvas.height = H * devicePixelRatio;
    ctx.scale(devicePixelRatio, devicePixelRatio);
  }
  resize();
  window.addEventListener('resize', resize);

const waves = [
    { freq: 0.008, amp:  76, speed: 0.18, phase: 0.0, boost: 1, opacity: 0.32, width: 1.2 },
    { freq: 0.013, amp:  44, speed: 0.28, phase: 2.1, boost: 1, opacity: 0.26, width: 0.8 },
    { freq: 0.021, amp:  24, speed: 0.42, phase: 4.2, boost: 1, opacity: 0.22, width: 1.6 },
    { freq: 0.005, amp: 110, speed: 0.10, phase: 4.4, boost: 1, opacity: 0.20, width: 0.6 },
    { freq: 0.020, amp:  28, speed: 0.42, phase: 1.3, boost: 1, opacity: 0.18, width: 0.5 },
    { freq: 0.031, amp:  16, speed: 0.60, phase: 3.7, boost: 1, opacity: 0.18, width: 2.0 },
    { freq: 0.004, amp: 140, speed: 0.07, phase: 0.8, boost: 1, opacity: 0.22, width: 0.7 },
    { freq: 0.017, amp:  36, speed: 0.35, phase: 5.1, boost: 1, opacity: 0.22, width: 0.9 },
    { freq: 0.025, amp:  60, speed: 0.22, phase: 1.8, boost: 1, opacity: 0.16, width: 0.4 },
    { freq: 0.040, amp:  12, speed: 0.75, phase: 0.4, boost: 1, opacity: 0.16, width: 2.4 },
    { freq: 0.003, amp: 180, speed: 0.05, phase: 3.2, boost: 1, opacity: 0.22, width: 1.0 },
    { freq: 0.005, amp: 180, speed: 0.30, phase: 2.5, boost: 1, opacity: 0.18, width: 0.7 },
];

  window.addEventListener('timeline-item', (e: Event) => {
    const { index } = (e as CustomEvent).detail;
    waves[index % waves.length].boost = 3.5;
  });

  let scrollY = 0;
  window.addEventListener('scroll', () => { scrollY = window.scrollY; }, { passive: true });

  let t = 0;

  function draw() {
    ctx.clearRect(0, 0, W, H);

    const isDark = document.documentElement.classList.contains('dark');
    const baseR = isDark ? 100 : 15;
    const baseG = isDark ? 160 : 60;
    const baseB = isDark ? 220 : 140;

    const scrollInfluence = scrollY * 0.004;

    waves.forEach((wave) => {
      const boost = wave.boost;
      const t2 = Math.min((boost - 1) / 2.5, 1);

      const wr = Math.round(baseR + (100 - baseR) * t2);
      const wg = Math.round(baseG + (160 - baseG) * t2);
      const wb = Math.round(baseB + (220 - baseB) * t2);

      const boostedAmp = wave.amp * boost;
      const boostedOpacity = wave.opacity * Math.min(boost, 2.5);

      const yBase = H * 0.5;
      ctx.beginPath();
      for (let x = 0; x <= W; x += 2) {
        const y = yBase
          + Math.sin(x * wave.freq + wave.phase + t * wave.speed + scrollInfluence) * boostedAmp
          + Math.sin(x * wave.freq * 0.5 + scrollInfluence * 0.7) * boostedAmp * 0.3;
        x === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }

      if (boost > 1.1) {
        ctx.strokeStyle = `rgba(100,160,220,${(boost - 1) * 0.06})`;
        ctx.lineWidth = wave.width * 6;
        ctx.stroke();
      }

      ctx.strokeStyle = `rgba(${wr},${wg},${wb},${boostedOpacity})`;
      ctx.lineWidth = wave.width * (boost > 1 ? 1.5 : 1);
      ctx.stroke();

      if (wave.boost > 1) wave.boost = Math.max(1, wave.boost - 0.018);
    });

    t += 0.016;
    requestAnimationFrame(draw);
  }

  draw();
</script>