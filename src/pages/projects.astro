---
import Layout from "../layouts/Layout.astro";
import { projects } from "../data/projects.ts";
---
<Layout title="Projects Page">
  <section id="projects">
    <div class="projects-container">
      <h2 class="projects-title">Projects</h2>
      <div class="filter-buttons">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="hardware">Hardware / RF</button>
        <button class="filter-btn" data-filter="software">Software</button>
      </div>
      <div class="projects-grid">
        {
          projects.map((project, i) => (
            <div class="project-card" data-category={project.category.join(" ")}>
              <div class="project-image">
                <img
                  src={project.images[0]}
                  alt={project.title}
                  width="600"
                  height="200"
                  loading={i < 3 ? "eager" : "lazy"}
                  decoding="async"
                />
              </div>
              <div class="project-info">
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <div class="project-tags">
                  {project.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
                <a href={`/projects/${project.slug}`} class="read-more">
                  Read More
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const cards = document.querySelectorAll<HTMLElement>(".project-card");

    // 1. Filter Logic
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        buttons.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        const filter = btn.dataset.filter;
        
        cards.forEach((card) => {
          if (filter === "all" || card.dataset.category!.includes(filter!)) {
            card.style.display = "flex";
          } else {
            card.style.display = "none";
          }
        });
      });
    });

    // 2. Scroll Animation Logic (Intersection Observer)
    const observerOptions = {
      root: null, // viewport
      rootMargin: "0px 0px -50px 0px", // Triggers slightly before entering full view
      threshold: 0.1, // Trigger when 10% of the card is visible
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("reveal");
          // Optional: Stop observing once animated so it doesn't re-trigger
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    cards.forEach((card) => observer.observe(card));
  </script>
</Layout>

<style>
  /* 3. Animation Styles */
  .project-card {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.6s cubic-bezier(0.25, 1, 0.5, 1), 
                transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    will-change: transform, opacity;
  }

  .project-card.reveal {
    opacity: 1;
    transform: translateY(0);
  }
</style>